{
  "manifest_version": 3,
  "name": "ToxiGuard AI",
  "version": "1.0.0",
  "description": "AI-powered toxic comment moderation for Instagram",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://toxiguard-ai-agent-1.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}